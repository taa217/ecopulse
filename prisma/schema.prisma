generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Member {
  id              String   @id @default(uuid())
  email           String   @unique
  password        String
  name            String
  registrationNumber String? @unique
  role            Role     @default(MEMBER)
  activityHistory String?
  position        String?
  birthdays       String?
  contactInfo     String?
  fieldOfStudy    String?
  yearOfStudy     String?
  ideas             Idea[]   @relation("IdeaCreator")
  collaboratedIdeas Idea[]   @relation("IdeaCollaborator")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Idea {
  id            String   @id @default(uuid())
  projectName   String
  description   String
  timeline      String?
  memberId      String?
  member        Member?  @relation("IdeaCreator", fields: [memberId], references: [id])
  collaborators Member[] @relation("IdeaCollaborator")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum Role {
  ADMIN
  MEMBER
}
